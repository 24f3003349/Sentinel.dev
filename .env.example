# Choose `google`, `openai`, or `openrouter`. The judge demo requires one live provider.
SENTINEL_LLM_PROVIDER=google
# Optional override. Google defaults to `gemini-3.5-flash`.
SENTINEL_LLM_MODEL=
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
# Optional OpenRouter app attribution.
SENTINEL_APP_URL=https://github.com/24f3003349/Sentinel.dev
# Optional external Graphify/GitNexus bridge. Use {target} as the placeholder.
# SENTINEL_GRAPHIFY_COMMAND=graphify export --format json {target}
# Optional GitHub PR creation after the local commit. Requires a configured remote and token.
GITHUB_TOKEN=
