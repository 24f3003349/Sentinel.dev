# Optional. Without this key Sentinel runs its deterministic offline demonstration.
OPENAI_API_KEY=
SENTINEL_OPENAI_MODEL=gpt-5.6-sol
# Optional external Graphify/GitNexus bridge. Use {target} as the placeholder.
# SENTINEL_GRAPHIFY_COMMAND=graphify export --format json {target}
# Optional GitHub PR creation after the local commit. Requires a configured remote and token.
GITHUB_TOKEN=
